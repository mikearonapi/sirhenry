# Auto-detect text files and normalize line endings to LF on commit
* text=auto eol=lf

# Force these to always use LF (Unix) endings
*.py text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.json text eol=lf
*.css text eol=lf
*.html text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
*.cfg text eol=lf
*.txt text eol=lf
*.sh text eol=lf
Dockerfile text eol=lf
Dockerfile.* text eol=lf
.gitignore text eol=lf
.gitattributes text eol=lf
.env.example text eol=lf

# Binary files — don't touch
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.db binary
*.sqlite binary
*.sqlite3 binary
*.pdf binary
