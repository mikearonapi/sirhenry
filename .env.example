# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# -----------------------------------------------
# AI
# -----------------------------------------------
ANTHROPIC_API_KEY=your_anthropic_api_key_here
CLAUDE_MODEL=claude-sonnet-4-20250514

# -----------------------------------------------
# Database
# -----------------------------------------------
DATABASE_URL=sqlite+aiosqlite:///./data/db/financials.db

# -----------------------------------------------
# API server
# -----------------------------------------------
API_HOST=127.0.0.1
API_PORT=8000

# -----------------------------------------------
# Frontend
# -----------------------------------------------
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000
# Required for Plaid OAuth redirect (Capital One, Chase, etc.)
# Must match an Allowed Redirect URI registered in your Plaid dashboard.
# Local dev example: http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -----------------------------------------------
# Plaid (bank / credit card sync)
# Sign up at https://dashboard.plaid.com/
# Client ID is the same across sandbox and production.
# -----------------------------------------------
PLAID_CLIENT_ID=your_plaid_client_id
# Production secret — used in local mode (real bank connections)
PLAID_SECRET=your_plaid_production_secret
# Sandbox secret — used in demo mode (test data, synthetic banks)
PLAID_SANDBOX_SECRET=your_plaid_sandbox_secret
# Default Plaid environment for local mode: sandbox | production
PLAID_ENV=production

# Required when PLAID_ENV=production — encrypts Plaid access tokens at rest.
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# WARNING: Back this key up. If lost, all bank accounts must be re-linked.
PLAID_ENCRYPTION_KEY=
PLAID_SYNC_INTERVAL_HOURS=6

# -----------------------------------------------
# Data Encryption — encrypts sensitive fields (names, SSNs, employers) at rest
# Falls back to PLAID_ENCRYPTION_KEY if not set separately.
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# -----------------------------------------------
DATA_ENCRYPTION_KEY=

# -----------------------------------------------
# CORS
# -----------------------------------------------
CORS_ORIGINS=  # Comma-separated allowed origins; leave blank for default

# -----------------------------------------------
# Notifications / Reminders
# Optional: SMTP for email reminders
# -----------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
NOTIFICATION_EMAIL=your_email@gmail.com
